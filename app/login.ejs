 <div id="loginContainer" style="display: none;">
    <div id="loginContent">
        <div id="loginLogoContainer">
            <img id="loginLogo" src="assets/images/VitarisLogo.png" alt="Vitaris II">
        </div>
        <h2 id="loginTitle">Iniciar Sesión</h2>
        <div id="loginForm">
            <div class="loginField">
                <input type="text" id="loginUsername" placeholder="Usuario o correo" tabindex="-1" autocomplete="off"/>
            </div>
            <div class="loginField">
                <input type="password" id="loginPassword" placeholder="Contraseña" tabindex="-1"/>
            </div>
            <div id="loginOptions">
                <label id="loginRememberOption">
                    <input type="checkbox" id="loginRememberCheckbox" tabindex="-1"/>
                    <span>Recordarme</span>
                </label>
            </div>
            <button id="loginButton" tabindex="-1">
                <span id="loginButtonText">ENTRAR</span>
            </button>
            <div id="loginSeparator"><span>o</span></div>
            <button id="loginMicrosoftButton" tabindex="-1">
                <svg id="microsoftIcon" viewBox="0 0 21 21" width="18" height="18">
                    <rect x="1" y="1" width="9" height="9" fill="#f25022"/>
                    <rect x="11" y="1" width="9" height="9" fill="#7fba00"/>
                    <rect x="1" y="11" width="9" height="9" fill="#00a4ef"/>
                    <rect x="11" y="11" width="9" height="9" fill="#ffb900"/>
                </svg>
                <span>Iniciar sesión con Microsoft</span>
            </button>
        </div>
        <div id="loginErrorContainer" style="display: none;">
            <p id="loginErrorMessage"></p>
        </div>
    </div>
</div>
