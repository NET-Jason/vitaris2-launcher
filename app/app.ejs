<html lang="es" xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta charset="utf-8"/>
    <title>Vitaris II Launcher</title>
    <link type="text/css" rel="stylesheet" href="./assets/css/launcher.css">
    <style>
        body {
            background-image: url('assets/images/backgrounds/<%=bkid%>.jpg');
            background-size: cover;
            background-position: center center;
            background-attachment: fixed;
            -webkit-user-select: none;
            transition: background-image 1s ease;
        }
        #main {
            display: none;
            height: calc(100% - 22px);
            background: linear-gradient(135deg, rgba(5,5,18,0.85) 0%, rgba(10,5,30,0.65) 50%, rgba(0,0,0,0.80) 100%);
            width: 100%;
            position: absolute;
            z-index: 10;
        }
        #main[overlay] { filter: blur(3px) contrast(0.9) brightness(0.9); }
    </style>
</head>
<body bkid="<%=bkid%>">

    <!-- FRAME -->
    <div id="frameBar">
        <div id="frameResizableTop"></div>
        <div id="frameMain">
            <div class="frameResizableVert"></div>
            <div id="frameContentWin">
                <div id="frameTitleDock"><span id="frameTitleText">VITARIS II</span></div>
                <div id="frameButtonDockWin">
                    <button class="frameButton" id="frameButton_minimize" tabindex="-1">
                        <svg width="10" height="1" viewBox="0 0 10 1"><rect width="10" height="1" fill="white"/></svg>
                    </button>
                    <button class="frameButton" id="frameButton_maximize" tabindex="-1">
                        <svg width="10" height="10" viewBox="0 0 10 10"><rect width="9" height="9" x="0.5" y="0.5" fill="none" stroke="white" stroke-width="1"/></svg>
                    </button>
                    <button class="frameButton" id="frameButton_close" tabindex="-1">
                        <svg width="10" height="10" viewBox="0 0 10 10">
                            <line x1="0" y1="0" x2="10" y2="10" stroke="white" stroke-width="1.2"/>
                            <line x1="10" y1="0" x2="0" y2="10" stroke="white" stroke-width="1.2"/>
                        </svg>
                    </button>
                </div>
            </div>
            <div id="frameContentDarwin" style="display:none;">
                <div id="frameButtonDockDarwin">
                    <button class="frameButtonDarwin" id="frameButtonDarwin_close" tabindex="-1"></button>
                    <button class="frameButtonDarwin" id="frameButtonDarwin_minimize" tabindex="-1"></button>
                    <button class="frameButtonDarwin" id="frameButtonDarwin_maximize" tabindex="-1"></button>
                </div>
            </div>
            <div class="frameResizableVert"></div>
        </div>
    </div>

    <div id="main">

        <!-- WELCOME -->
        <div id="welcomeContainer" style="display:none;">
            <div id="welcomeContent">
                <div id="welcomeLogoContainer">
                    <img id="welcomeLogo" src="assets/images/VitarisLogo.png" alt="Vitaris II">
                </div>
                <h1 id="welcomeTitle">VITARIS II</h1>
                <p id="welcomeDesc">El launcher oficial del servidor.<br>Mods y actualizaciones gestionadas automáticamente.</p>
                <button id="welcomeButton" tabindex="-1">
                    <span>COMENZAR</span>
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                        <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </button>
            </div>
        </div>

        <!-- LOGIN -->
        <div id="loginContainer" style="display:none;">
            <div id="loginContent">
                <div id="loginLogoContainer">
                    <img src="assets/images/VitarisLogo.png" alt="Vitaris II" style="width:60px;height:60px;object-fit:contain;">
                </div>
                <h2 id="loginTitle">Iniciar Sesión</h2>
                <div id="loginForm">
                    <div class="loginField"><input type="text" id="loginUsername" placeholder="Usuario o correo" tabindex="-1" autocomplete="off"/></div>
                    <div class="loginField"><input type="password" id="loginPassword" placeholder="Contraseña" tabindex="-1"/></div>
                    <button id="loginButton" tabindex="-1"><span id="loginButtonText">ENTRAR</span></button>
                    <div id="loginSeparator"><span>o</span></div>
                    <button id="loginMicrosoftButton" tabindex="-1">
                        <svg viewBox="0 0 21 21" width="18" height="18">
                            <rect x="1" y="1" width="9" height="9" fill="#f25022"/>
                            <rect x="11" y="1" width="9" height="9" fill="#7fba00"/>
                            <rect x="1" y="11" width="9" height="9" fill="#00a4ef"/>
                            <rect x="11" y="11" width="9" height="9" fill="#ffb900"/>
                        </svg>
                        <span>Iniciar sesión con Microsoft</span>
                    </button>
                </div>
                <div id="loginErrorContainer" style="display:none;">
                    <p id="loginErrorMessage"></p>
                </div>
            </div>
        </div>

        <!-- WAITING -->
        <div id="waitingContainer" style="display:none;">
            <div id="waitingContent">
                <div class="waitingSpinner"></div>
                <p id="waitingMessage">Verificando cuenta...</p>
            </div>
        </div>

        <!-- LOGIN OPTIONS -->
        <div id="loginOptionsContainer" style="display:none;">
            <div id="loginOptionsContent">
                <h2>Selecciona una cuenta</h2>
                <div id="loginOptionsList"></div>
                <button id="loginOptionsAddButton" tabindex="-1"><span>+ Agregar cuenta</span></button>
                <button id="loginOptionsCancelButton" tabindex="-1"><span>Cancelar</span></button>
            </div>
        </div>

        <!-- LANDING -->
        <div id="landingContainer" style="display:none;">
            <div id="landingLeft">
                <div id="serverInfo">
                    <div id="serverStatusContainer">
                        <span id="serverStatusIcon"></span>
                        <span id="serverStatusText">Conectando...</span>
                    </div>
                    <p id="serverName">Vitaris II</p>
                    <p id="serverAddress">play.vitaris.net</p>
                </div>
                <div id="newsContainer">
                    <h3 id="newsTitle">Noticias</h3>
                    <div id="newsContent">
                        <div class="newsEntry">
                            <p class="newsEntryTitle">¡Bienvenido a Vitaris II!</p>
                            <p class="newsEntryDesc">El servidor ha sido actualizado. Disfruta de las nuevas zonas y mecánicas.</p>
                        </div>
                    </div>
                </div>
            </div>
            <div id="landingRight">
                <div id="playerInfoContainer">
                    <img id="playerAvatar" src="assets/images/default_avatar.png" alt="Avatar">
                    <div id="playerDetails">
                        <p id="playerName">Jugador</p>
                        <p id="playerType">Microsoft</p>
                    </div>
                    <button id="playerSwitchButton" tabindex="-1">
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                            <path d="M1 7C1 3.686 3.686 1 7 1s6 2.686 6 6-2.686 6-6 6" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                            <path d="M4 10l-3 3M4 10H1M4 10v3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </button>
                </div>
                <div id="launchContainer">
                    <div id="progressContainer" style="display:none;">
                        <p id="progressStatus">Descargando...</p>
                        <div id="progressBar"><div id="progressBarFill"></div></div>
                        <p id="progressValue">0%</p>
                    </div>
                    <button id="launchButton" tabindex="-1"><span id="launchButtonText">JUGAR</span></button>
                </div>
                <div id="settingsNavContainer">
                    <button id="settingsNavButton" tabindex="-1">
                        <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                            <circle cx="9" cy="9" r="2.5" stroke="currentColor" stroke-width="1.3"/>
                            <path d="M9 1v2M9 15v2M1 9h2M15 9h2M3.22 3.22l1.42 1.42M13.36 13.36l1.42 1.42M14.78 3.22l-1.42 1.42M4.64 13.36l-1.42 1.42" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                        </svg>
                        <span>Configuración</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- SETTINGS -->
        <div id="settingsContainer" style="display:none;">
            <div id="settingsHeader">
                <button id="settingsBack" tabindex="-1">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                        <path d="M13 8H3M3 8L7 4M3 8L7 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span>Volver</span>
                </button>
                <h2>Configuración</h2>
            </div>
            <div id="settingsContent">
                <div class="settingsSection">
                    <h3 class="settingsSectionTitle">Java</h3>
                    <div class="settingsField">
                        <label>Ruta de Java</label>
                        <div class="settingsInputRow">
                            <input type="text" id="javaPath" placeholder="Automático" tabindex="-1"/>
                            <button id="javaPathBrowse" tabindex="-1">Buscar</button>
                        </div>
                    </div>
                    <div class="settingsField">
                        <label>RAM Mínima (MB)</label>
                        <input type="number" id="minRam" value="1024" min="512" tabindex="-1"/>
                    </div>
                    <div class="settingsField">
                        <label>RAM Máxima (MB)</label>
                        <input type="number" id="maxRam" value="4096" min="1024" tabindex="-1"/>
                    </div>
                </div>
                <div class="settingsSection">
                    <h3 class="settingsSectionTitle">Launcher</h3>
                    <div class="settingsField settingsToggle">
                        <label>Cerrar launcher al iniciar juego</label>
                        <div class="toggleSwitch" id="closeLauncherToggle"><div class="toggleKnob"></div></div>
                    </div>
                    <div class="settingsField settingsToggle">
                        <label>Permitir versiones pre-release</label>
                        <div class="toggleSwitch" id="prereleaseToggle"><div class="toggleKnob"></div></div>
                    </div>
                </div>
                <div class="settingsSection">
                    <h3 class="settingsSectionTitle">Acerca de</h3>
                    <div class="settingsAbout">
                        <img src="assets/images/VitarisLogo.png" alt="Vitaris II" id="settingsLogo">
                        <p id="settingsVersion">Vitaris II Launcher v1.0.0</p>
                        <p id="settingsAuthor">Desarrollado por <a id="settingsAuthorLink">NET-Jason</a></p>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- OVERLAY -->
    <div id="overlayContainer" style="display:none;">
        <div id="overlayContent">
            <div id="overlayTitle"></div>
            <div id="overlayDesc"></div>
            <div id="overlayActionContainer">
                <button id="overlayActionConfirm" tabindex="-1">Confirmar</button>
                <button id="overlayActionCancel" tabindex="-1">Cancelar</button>
            </div>
        </div>
    </div>

    <!-- LOADING -->
    <div id="loadingContainer">
        <div id="loadingContent">
            <div id="loadSpinnerContainer">
                <img id="loadCenterImage" src="assets/images/VitarisLogo.png">
            </div>
        </div>
    </div>

    <script src="./assets/js/scripts/uicore.js"></script>
    <script src="./assets/js/scripts/uibinder.js"></script>
</body>
</html>